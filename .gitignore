# PadaiSathi Root .gitignore
node_modules/
venv/
env/
.venv/
__pycache__/
*.pyc

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build
build/
dist/
.next/
out/

# Database - NEVER commit
*.db
*.db-journal

# Huge files that breaks your push
backend/generated_videos/
backend/temp_video/
backend/uploads/
minio-data/
*.exe
mc.exe
minio.exe

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
# Frontend video assets
frontend/src/assets/backgrounds/*.mp4
frontend/src/assets/videos/

# Video files
*.mp4
frontend/src/assets/backgrounds/*.mp4

# Environment variables
.env
*.env
# AI/ML models 
backend/app/ai/model/
backend/app/ai/model/*
!backend/app/ai/model/*.py   # optional: keep python files if any
!backend/app/ai/model/*.json # keep configs if needed
# Large AI/ML model files, too big for Git, download separately
backend/app/ai/model/model.safetensors
backend/app/ai/model/*.safetensors
backend/app/ai/model/*.bin
backend/app/ai/model/*.pt
